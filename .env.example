# ═══════════════════════════════════════════════════════
# Lighter Quant Bot — 环境变量配置
# 复制此文件为 .env 并填入你的真实值
# cp .env.example .env
# ═══════════════════════════════════════════════════════

# ── Lighter.xyz API 凭证 (必填) ──────────────────────
# 从 Lighter.xyz 账户获取以下信息:
#   1. 登录 https://lighter.xyz
#   2. 进入 Account → API Keys
#   3. 创建新的 API Key，记录 key 和 secret
#   4. Account Index 在 Profile 页面可以看到
#   5. API Key Index 是创建 key 时分配的编号

LIGHTER_API_KEY=your_api_key_here
LIGHTER_SECRET_KEY=your_secret_key_hex_here
LIGHTER_PRIVATE_KEY=your_l1_private_key_hex_here
LIGHTER_ACCOUNT_INDEX=0
LIGHTER_API_KEY_INDEX=0

# ── 网络选择 ──────────────────────────────────────────
# mainnet = 主网实盘交易 (真实资金)
# testnet = 测试网 (模拟交易)
LIGHTER_NETWORK=mainnet

# ── 交易配置 ──────────────────────────────────────────
INITIAL_CAPITAL=100
RISK_PER_TRADE=2
MAX_POSITIONS=5

# ── 系统配置 ──────────────────────────────────────────
RUST_LOG=info
TOKIO_WORKER_THREADS=4

# ── 可选: lighter-signer.so 路径 ─────────────────────
# 如不设置，程序会依次查找:
#   1. 可执行文件同目录
#   2. 当前工作目录 ./lighter-signer.so
#   3. Docker 容器内 /app/lighter-signer.so
# LIGHTER_SIGNER_PATH=/path/to/lighter-signer.so
