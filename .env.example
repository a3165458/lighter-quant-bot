# ═══════════════════════════════════════════════════════
# Lighter Quant Bot — 环境变量配置
# 复制此文件为 .env 并填入你的真实值
# cp .env.example .env
# ═══════════════════════════════════════════════════════

# ── Lighter API 凭证 (必填，只需以下三项) ─────────────
# 生成方式: 登录交易所 → Account → API Keys → 创建 API Key
#   主网:           https://app.lighter.xyz
#   Robinhood Chain: https://robinhoodchain.lighter.xyz  (账户体系与主网独立)
#
# 生成弹窗字段对应关系:
#   "私钥 (Private Key)"   → LIGHTER_SECRET_KEY   (API 私钥 hex，弹窗关闭后无法再查看!)
#   "您的账户索引"          → LIGHTER_ACCOUNT_INDEX
#   "API 密钥索引"          → LIGHTER_API_KEY_INDEX
#   "公钥 (Public Key)"    → 无需填写（已注册在交易所侧）
# 注意: 这里是 Lighter 的 API 私钥，不是钱包的 L1 私钥

LIGHTER_SECRET_KEY=your_api_private_key_hex_here
LIGHTER_ACCOUNT_INDEX=0
LIGHTER_API_KEY_INDEX=0

# ── 系统配置 ──────────────────────────────────────────
RUST_LOG=info
TOKIO_WORKER_THREADS=4

# ── 可选: lighter-signer.so 路径 ─────────────────────
# 如不设置，程序会依次查找:
#   1. 可执行文件同目录
#   2. 当前工作目录 ./lighter-signer.so
#   3. Docker 容器内 /app/lighter-signer.so
# LIGHTER_SIGNER_PATH=/path/to/lighter-signer.so
